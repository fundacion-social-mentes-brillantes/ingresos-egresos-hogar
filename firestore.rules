rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Super-admin por correo (ancla de confianza, no depende de ningun doc).
    function isSuperAdmin() {
      return request.auth != null
        && request.auth.token.email == 'fundacionsocial@gimnasioemocionalmb.com';
    }

    // Admin de la app: el super-admin, o quien tenga un doc de acceso aprobado
    // con rol admin (nombrado por el super-admin).
    function isAppAdmin() {
      return isSuperAdmin() || (
        request.auth != null
        && exists(/databases/$(database)/documents/accessControl/$(request.auth.uid))
        && get(/databases/$(database)/documents/accessControl/$(request.auth.uid)).data.role == 'admin'
        && get(/databases/$(database)/documents/accessControl/$(request.auth.uid)).data.status == 'approved'
      );
    }

    // Dinero SIN decimales (pesos COP enteros). Acepta int y tambien doubles
    // enteros legacy (45000.0) para no bloquear reversos de datos antiguos,
    // pero rechaza cualquier monto con decimales que corromperia los saldos.
    // NO se validan tamanos de texto aqui: los asientos de reverso/correccion
    // anteponen prefijos ("Reverso de: ...") y un tope rechazaria escrituras
    // legitimas del propio motor. El control de tamano, si se quiere, va en la app.
    function wholeMoney(value) {
      return value is number && value == math.floor(value);
    }

    function validTransaction(data) {
      return data.type in ['income', 'expense']
        && wholeMoney(data.amount)
        && data.amount > 0
        && data.currency == 'COP'
        && data.category is string
        && data.accountId is string
        && data.accountName is string
        && data.description is string
        && data.date is timestamp;
    }

    function validDebt(data) {
      return data.direction in ['receivable', 'payable']
        && data.personName is string
        && wholeMoney(data.amountOriginal)
        && data.amountOriginal > 0
        && wholeMoney(data.amountPaid)
        && data.amountPaid >= 0
        && data.amountPaid <= data.amountOriginal
        && data.currency == 'COP'
        && data.description is string
        && data.status in ['open', 'partial', 'paid'];
    }

    // La papelera mueve dinero al restaurar: su contenido tambien se valida.
    function validDeletedTransaction(data) {
      return data.type in ['income', 'expense']
        && wholeMoney(data.amount)
        && data.amount > 0
        && data.originalId is string;
    }

    function validChatMessage(data) {
      return data.sender in ['user', 'bot']
        && data.text is string;
    }

    match /users/{userId} {
      // El PERFIL (nombre, correo y foto de perfil) lo puede leer un admin para
      // el panel de administracion. Las reglas NO se heredan: los datos
      // financieros viven en las subcolecciones de abajo y siguen siendo SOLO
      // del dueno (ni el admin puede leerlos).
      allow get: if isOwner(userId) || isAppAdmin();
      allow list: if isAppAdmin();
      allow create, update, delete: if isOwner(userId);

      match /transactions/{transactionId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && validTransaction(request.resource.data);
        // En update NO re-exigimos todos los campos (un movimiento legacy podria
        // no tenerlos y marcar isReversed lo rechazaria), pero SI blindamos el
        // dinero: nunca un monto con decimales o negativo.
        allow update: if isOwner(userId)
          && wholeMoney(request.resource.data.amount)
          && request.resource.data.amount > 0;
        allow delete: if isOwner(userId);
      }

      match /accounts/{accountId} {
        allow read, write: if isOwner(userId);
      }

      match /chatMessages/{messageId} {
        allow read, delete: if isOwner(userId);
        allow create: if isOwner(userId) && validChatMessage(request.resource.data);
        allow update: if isOwner(userId) && validChatMessage(request.resource.data);
      }

      match /debts/{debtId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && validDebt(request.resource.data);
        // Update laxo en forma, estricto en dinero (abonos y anulacion tocan
        // amountPaid/status): montos enteros y amountPaid nunca supera el total.
        allow update: if isOwner(userId)
          && wholeMoney(request.resource.data.amountOriginal)
          && wholeMoney(request.resource.data.amountPaid)
          && request.resource.data.amountPaid >= 0
          && request.resource.data.amountPaid <= request.resource.data.amountOriginal;
        allow delete: if isOwner(userId);
      }

      match /deletedTransactions/{deletedId} {
        allow read, delete: if isOwner(userId);
        allow create: if isOwner(userId) && validDeletedTransaction(request.resource.data);
        allow update: if isOwner(userId) && validDeletedTransaction(request.resource.data);
      }

      match /backupExports/{backupId} {
        allow read, write: if isOwner(userId);
      }

      match /actionLogs/{logId} {
        allow read, write: if isOwner(userId);
      }

      match /accountingAudit/{auditId} {
        allow read, write: if isOwner(userId);
      }

      match /aiMemory/{memoryId} {
        allow read, write: if isOwner(userId);
      }

      match /settings/{settingId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Porton de acceso al programa (aprobacion por admin). NO guarda datos
    // financieros; solo quien puede usar la app y con que rol.
    match /accessControl/{docId} {
      allow get: if request.auth != null && (request.auth.uid == docId || isAppAdmin());
      allow list: if isAppAdmin();
      // Un usuario crea SOLO su propia solicitud, forzosamente pendiente y rol
      // user: nadie se auto-aprueba ni se hace admin. Un admin SI puede crear
      // el doc de otro (pre-aprobar a alguien registrado que aun no ha entrado).
      allow create: if (request.auth != null
          && request.auth.uid == docId
          && request.resource.data.status == 'pending'
          && request.resource.data.role == 'user')
        || isAppAdmin();
      // Solo un admin decide estado/rol. El propio usuario NO edita su doc.
      allow update: if isAppAdmin();
      allow delete: if isSuperAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
